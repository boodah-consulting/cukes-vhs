.TH "CUKES-VHS" "1" "Feb 2026" "cukes-vhs" "cukes-vhs Manual"

.SH NAME
cukes-vhs-run - Full pipeline: generate → render → validate


.SH SYNOPSIS
\fBcukes-vhs run [flags]\fP


.SH DESCRIPTION
Run the full cukes-vhs pipeline: generate → render → validate.

.PP
Generates VHS tape files from translatable scenarios, renders them using vhs,
and validates the output against golden baselines.


.SH OPTIONS
\fB--all\fP[=false]
	Run pipeline for all translatable scenarios

.PP
\fB--binary-path\fP=""
	Path to vhs binary (default: vhs in PATH)

.PP
\fB--config-source\fP="config/config.tape"
	Path to config tape file

.PP
\fB--feature\fP=""
	Filter by feature name

.PP
\fB--features\fP="features/"
	Directory containing .feature files

.PP
\fB--golden\fP="demos/golden/"
	Golden baseline directory

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for run

.PP
\fB--output\fP=""
	Output directory for generated tapes (required)

.PP
\fB--scenario\fP=""
	Filter by scenario name

.PP
\fB--scenarios-dir\fP="demos/scenarios/"
	Directory containing VHS-only .feature files

.PP
\fB--timeout\fP=120
	Per-tape render timeout in seconds

.SH EXAMPLE
.EX
  cukes-vhs run --all --output /tmp/tapes/ --golden demos/golden/
  cukes-vhs run --feature onboarding --output /tmp/tapes/
  cukes-vhs run --scenario "User logs in" --output /tmp/tapes/
.EE


.SH SEE ALSO
\fBcukes-vhs(1)\fP


