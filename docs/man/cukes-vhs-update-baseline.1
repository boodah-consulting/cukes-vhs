.TH "CUKES-VHS" "1" "Feb 2026" "cukes-vhs" "cukes-vhs Manual"

.SH NAME
cukes-vhs-update-baseline - Accept current output as new golden baseline


.SH SYNOPSIS
\fBcukes-vhs update-baseline [scenarios...] [flags]\fP


.SH DESCRIPTION
Accept current rendered output as the new golden baseline.

.PP
Use --all to accept all current outputs, or specify scenario names to
update specific baselines.


.SH OPTIONS
\fB--all\fP[=false]
	Accept all current outputs as golden baselines

.PP
\fB--golden\fP="demos/golden/"
	Golden baseline directory

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for update-baseline

.PP
\fB--output\fP=""
	Output directory containing rendered .ascii files (required)


.SH EXAMPLE
.EX
  cukes-vhs update-baseline --all --output /tmp/tapes/ --golden demos/golden/
  cukes-vhs update-baseline my-scenario --output /tmp/tapes/
  cukes-vhs update-baseline "User logs in" "User logs out" --output /tmp/tapes/
.EE


