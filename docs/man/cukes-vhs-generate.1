.TH "CUKES-VHS" "1" "Feb 2026" "cukes-vhs" "cukes-vhs Manual"

.SH NAME
cukes-vhs-generate - Generate VHS tape files from scenarios


.SH SYNOPSIS
\fBcukes-vhs generate [flags]\fP


.SH DESCRIPTION
Generate VHS tape files from Gherkin scenarios.

.PP
Parses feature files and generates .tape files for translatable scenarios.
Use --all to generate for all translatable scenarios, or filter by feature
or scenario name.


.SH OPTIONS
\fB--all\fP[=false]
	Generate for all translatable scenarios

.PP
\fB--binary-path\fP=""
	Path to vhs binary (default: vhs in PATH)

.PP
\fB--config-source\fP="config/config.tape"
	Path to config tape file

.PP
\fB--feature\fP=""
	Filter by feature name

.PP
\fB--features\fP="features/"
	Directory containing .feature files

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for generate

.PP
\fB--output\fP=""
	Output directory (required)

.PP
\fB--scenario\fP=""
	Filter by scenario name

.PP
\fB--scenarios-dir\fP="demos/scenarios/"
	Directory containing VHS-only .feature files

.PP
\fB--timeout\fP=120
	Per-tape render timeout in seconds

.PP
\fB--verbose\fP[=false]
	Verbose output


.SH EXAMPLE
.EX
  cukes-vhs generate --all --output /tmp/tapes/
  cukes-vhs generate --all --features features/ --scenarios-dir demos/scenarios/ --output /tmp/tapes/
  cukes-vhs generate --feature onboarding --output /tmp/test/
  cukes-vhs generate --scenario "User logs in" --output /tmp/test/
.EE


.SH SEE ALSO
\fBcukes-vhs(1)\fP


