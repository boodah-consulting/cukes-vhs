.TH "CUKES-VHS" "1" "Feb 2026" "cukes-vhs" "cukes-vhs Manual"

.SH NAME
cukes-vhs-list - List scenarios and their translatability


.SH SYNOPSIS
\fBcukes-vhs list [flags]\fP


.SH DESCRIPTION
List all scenarios from feature files and show their translatability status.

.PP
By default, outputs a formatted table showing each scenario with its feature,
source (business or VHS-only), and whether it can be translated to VHS commands.


.SH OPTIONS
\fB--all\fP[=false]
	List all scenarios (default behaviour)

.PP
\fB--count\fP[=false]
	Show counts broken down by source

.PP
\fB--features\fP="features/"
	Directory containing .feature files

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--json\fP[=false]
	Output as JSON

.PP
\fB--scenarios-dir\fP="demos/scenarios/"
	Directory containing VHS-only .feature files

.PP
\fB--steps\fP[=false]
	Show translatable step patterns


.SH EXAMPLE
.EX
  cukes-vhs list
  cukes-vhs list --features features/ --scenarios-dir demos/scenarios/
  cukes-vhs list --json
  cukes-vhs list --count
  cukes-vhs list --steps
  cukes-vhs list --steps --json
.EE


.SH SEE ALSO
\fBcukes-vhs(1)\fP


