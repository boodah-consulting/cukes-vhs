#!/bin/bash

# This hook is invoked before the commit message editor is opened
# It adds AI attribution template to the commit message

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2
SHA1=$3

# Only process regular commits (not merges, amends, etc.)
if [ -z "$COMMIT_SOURCE" ]; then
    # Check if there are code files in the staged changes
    CODE_FILES=$(git diff --cached --name-only | grep -E '\.(go|js|ts|py|java|c|cpp|rs)$' || true)

    if [ -n "$CODE_FILES" ]; then
        # Check if commit message already has content
        if ! grep -q "AI-Generated-By:" "$COMMIT_MSG_FILE" 2>/dev/null; then
            # Add reminder about AI attribution
            cat >> "$COMMIT_MSG_FILE" << 'EOF'

# ⚠️  REMINDER: If AI-generated code, uncomment and fill:
# AI-Generated-By: <Assistant Name> (<Model Version>)
# Reviewed-By: Your Name <your.email@example.com>
#
# Examples:
#   AI-Generated-By: Avante (Claude 3.5 Sonnet)
#   AI-Generated-By: Claude (Claude 3.7 Sonnet)
#   AI-Generated-By: GitHub Copilot (GPT-4)
EOF
        fi
    fi
fi

exit 0
