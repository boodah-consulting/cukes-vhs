#!/bin/bash
# Pre-commit hook for cukes-vhs
# Runs code quality checks before allowing commit

set -euo pipefail

echo "Running pre-commit checks..."

# Format check
echo "  → Checking code formatting..."
if [ -n "$(gofmt -l . 2>/dev/null)" ]; then
    echo "ERROR: Some files are not formatted. Run 'go fmt ./...'"
    gofmt -l .
    exit 1
fi

# Vet check
echo "  → Running go vet..."
if ! go vet ./... 2>/dev/null; then
    echo "ERROR: go vet failed"
    exit 1
fi

# Staticcheck (if available)
echo "  → Running staticcheck..."
if command -v staticcheck >/dev/null 2>&1; then
    if ! staticcheck ./... 2>/dev/null; then
        echo "ERROR: staticcheck failed"
        exit 1
    fi
else
    echo "    ⚠️  staticcheck not installed, skipping"
fi

# Build check
echo "  → Building..."
if ! go build ./... 2>/dev/null; then
    echo "ERROR: build failed"
    exit 1
fi

# Test check
echo "  → Running tests..."
if ! go test ./... 2>/dev/null; then
    echo "ERROR: tests failed"
    exit 1
fi

echo "✅ Pre-commit checks passed"
exit 0
